# --- Backend (Maven / Java) ---
backend/target/
*.class

# --- Frontend (Node) ---
frontend/node_modules/
frontend/dist/
npm-debug.log*

# --- Environment / secrets (never commit these) ---
.env
.env.*
*.env
backend/.env
frontend/.env
frontend/.env.local
# local override configs that may hold credentials
application-local.properties
application-local.yml
secrets.*
*.secret
*.secrets
# keys / certs
*.pem
*.key
*.p12
*.pfx
# allow committing an example template (no real values)
!.env.example

# --- IDE / OS ---
.idea/
*.iml
.vscode/
.DS_Store
Thumbs.db
